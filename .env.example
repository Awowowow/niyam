# API
PORT=4000
NIYAM_SOLVER_URL=http://127.0.0.1:8000

# Web
NEXT_PUBLIC_NIYAM_API_URL=http://localhost:4000/api

# AI on Amazon Bedrock (no OPENAI_API_KEY or cash payment required)
AWS_REGION=us-east-2
AWS_PROFILE=
NIYAM_CODEX_MODEL=openai.gpt-5.5
NIYAM_AI_BACKEND=bedrock-chat
NIYAM_POLICY_MODEL=openai.gpt-oss-120b
NIYAM_REPAIR_MODEL=qwen.qwen3-coder-480b-a35b-instruct
NIYAM_ENABLE_AI_EXTRACTION=false
NIYAM_ENABLE_CODEX_REPAIRS=false
NIYAM_JUDGE_MODE=false

# Ed25519 PKCS8 PEM, base64-encoded. If omitted, local demo mode uses an
# explicitly labelled ephemeral key that changes on every API restart.
NIYAM_EVIDENCE_PRIVATE_KEY_BASE64=

# Real PR publishing uses the locally authenticated GitHub CLI after two
# approvals and an explicit confirmPublish=true request.
# GH_TOKEN=

# Alternative Bedrock authentication:
# AWS_BEARER_TOKEN_BEDROCK=
