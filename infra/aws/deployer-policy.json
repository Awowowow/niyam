{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "NiyamDeploymentServices",
      "Effect": "Allow",
      "Action": [
        "cloudfront:*",
        "ec2:*",
        "ecs:*",
        "elasticloadbalancing:*",
        "logs:*",
        "secretsmanager:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ManageOnlyNiyamRoles",
      "Effect": "Allow",
      "Action": [
        "iam:AttachRolePolicy",
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:DeleteRolePolicy",
        "iam:DetachRolePolicy",
        "iam:GetRole",
        "iam:GetRolePolicy",
        "iam:ListAttachedRolePolicies",
        "iam:ListRolePolicies",
        "iam:PassRole",
        "iam:PutRolePolicy",
        "iam:TagRole",
        "iam:UntagRole",
        "iam:UpdateAssumeRolePolicy"
      ],
      "Resource": "arn:aws:iam::*:role/niyam-*"
    },
    {
      "Sid": "CreateRequiredServiceLinkedRoles",
      "Effect": "Allow",
      "Action": "iam:CreateServiceLinkedRole",
      "Resource": "*",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "iam:AWSServiceName": [
            "ecs.amazonaws.com",
            "elasticloadbalancing.amazonaws.com"
          ]
        }
      }
    }
  ]
}
